            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path obo:hasRelatedSynonym ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A biological process is the execution of a genetically-encoded biological module or program. It consists of all the steps required to achieve the specific biological objective of the module. A biological process is accomplished by a particular set of molecular functions carried out by specific gene products (or macromolecular complexes), often in a highly regulated manner and in a particular temporal sequence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path GO:0008150 ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path nlm-ckn:ontology_purl ;
            sh:pattern "CL:[0-9]{7}" ],
        [ sh:datatype xsd:string ;
            sh:description "An annotation property that links an ontology entity or a statement to a prefixed identifier or URI." ;
