            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellTypeSubclassOfCellType .

nlm-ckn:DrugEvaluatedInClinicalTrial a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a drug and some clinical trial it was tested in." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a drug and some clinical trial it was tested in." ;
