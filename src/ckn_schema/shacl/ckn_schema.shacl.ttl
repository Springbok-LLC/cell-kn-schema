@prefix CHEBI: <https://purl.obolibrary.org/obo/CHEBI_> .
@prefix CL: <https://purl.obolibrary.org/obo/CL_> .
@prefix DRON: <https://purl.obolibrary.org/obo/DRON_> .
@prefix GO: <https://purl.obolibrary.org/obo/GO_> .
@prefix IAO: <https://purl.obolibrary.org/obo/IAO_> .
@prefix MONDO: <https://purl.obolibrary.org/obo/MONDO_> .
@prefix NCBITaxon: <https://purl.obolibrary.org/obo/NCBITaxon_> .
@prefix OBI: <https://purl.obolibrary.org/obo/OBI_> .
@prefix PATO: <https://purl.obolibrary.org/obo/PATO_> .
@prefix PR: <https://purl.obolibrary.org/obo/PR_> .
@prefix SO: <https://purl.obolibrary.org/obo/SO_> .
@prefix UBERON: <https://purl.obolibrary.org/obo/UBERON_> .
@prefix nlm-ckn: <https://w3id.org/nlm-ckn-schema> .
@prefix obo: <http://www.geneontology.org/formats/oboInOwl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

CHEBI:24431 a sh:NodeShape ;
    sh:closed true ;
    sh:description "A chemical entity is a physical entity of interest in chemistry including molecular entities, parts thereof, and chemical substances." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name for an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:ontology_purl ] ;
    sh:targetClass CHEBI:24431 .

PATO:0000001 a sh:NodeShape ;
    sh:closed true ;
    sh:description "A dependent entity that inheres in a bearer by virtue of how the bearer is related to other entities." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The official description of something that explains its meaning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path IAO:0000115 ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:ontology_purl ],
        [ sh:datatype xsd:string ;
            sh:description "The name for an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass PATO:0000001 .

SO:0001537 a sh:NodeShape ;
    sh:closed true ;
    sh:description "The predicted effect of a sequence variant on a gene product or genomic feature, classified using Sequence Ontology terms." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A label describing the predicted consequence of a sequence variant." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:variant_consequence_label ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nlm-ckn:ontology_purl ] ;
    sh:targetClass SO:0001537 .

UBERON:0000105 a sh:NodeShape ;
    sh:closed true ;
    sh:description "A spatiotemporal region encompassing some part of the life cycle of an organism." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name for an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A Uniform Resource Locator that redirects to an ontology resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:ontology_purl ],
        [ sh:datatype xsd:string ;
            sh:description "The official description of something that explains its meaning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path IAO:0000115 ] ;
    sh:targetClass UBERON:0000105 .

nlm-ckn:AnatomicalStructurePartOfAnatomicalStructure a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between an anatomical structure and another anatomical structure it is part of." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a part and some whole entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:AnatomicalStructurePartOfAnatomicalStructure .

nlm-ckn:Association a sh:NodeShape ;
    sh:closed true ;
    sh:description "A typed association between two entities, linked by a predicate." ;
    sh:ignoredProperties ( rdf:type <dc:source> ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "The predicate of a triple." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "The object of a triple." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:string ;
            sh:description "The subject of a triple." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ] ;
    sh:targetClass nlm-ckn:Association .

nlm-ckn:BiomarkerCombinationSubclusterOfBinaryGeneSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a biomarker combination and a set of binary genes that its members are a member of." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class SO:0001260 ;
            sh:description "A cell type marker gene is a gene that is selectively expressed in cells of a given type and can be reliably used alone or in combination as a canonical characteristic to optimally classify them." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class SO:0001260 ;
            sh:description "A collection of discontinuous sequences." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a group and another group it is part of but does not fully constitute." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:BiomarkerCombinationSubclusterOfBinaryGeneSet .

nlm-ckn:CellSetComposedPrimarilyOfCellType a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and a cell type that comprises most or all of the set." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between two material entities in which more than half of the mass of one is made from the other or units of the same type as the other material entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellSetComposedPrimarilyOfCellType .

nlm-ckn:CellSetDatasetHasSourcePublication a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set dataset and the publication that can be used as a reference for it." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A relation between some information content entity and the resource from which it originated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class nlm-ckn:CellSetDataset ;
            sh:description "A dataset that is about cells taken from one or more tissue samples." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class IAO:0000311 ;
            sh:description "A document that is the output of a publishing process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellSetDatasetHasSourcePublication .

nlm-ckn:CellSetDerivesFromAnatomicalStructure a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and an anatomical structure it was extracted from for analysis." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class UBERON:0001062 ;
            sh:description "Material anatomical entity that is a single connected structure with inherent 3D shape generated by coordinated expression of the organism's own genome." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between two material entities, the new entity and the old entity, in which the new entity begins to exist when the old entity ceases to exist, and the new entity inherits the significant portion of the matter of the old entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ] ;
    sh:targetClass nlm-ckn:CellSetDerivesFromAnatomicalStructure .

nlm-ckn:CellSetExactMatchCellSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between two cell sets that are both instances of the same cell type that have been mapped to each other." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A mapping relation between two entities that are of the same type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ] ;
    sh:targetClass nlm-ckn:CellSetExactMatchCellSet .

nlm-ckn:CellSetExpressesBinaryGeneSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and a set of binary genes that it expresses." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "relation between some biological entity and a gene that is the input of some gene expression process" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class SO:0001260 ;
            sh:description "A collection of discontinuous sequences." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellSetExpressesBinaryGeneSet .

nlm-ckn:CellSetHasCharacterizingMarkerSetBiomarkerCombination a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and a biomarker combination that can be used to uniquely identify it." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A relation that applies between a set of markers and a cell type that can be used to uniquely identify that cell type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class SO:0001260 ;
            sh:description "A cell type marker gene is a gene that is selectively expressed in cells of a given type and can be reliably used alone or in combination as a canonical characteristic to optimally classify them." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellSetHasCharacterizingMarkerSetBiomarkerCombination .

nlm-ckn:CellSetHasSourceCellSetDataset a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell set and the dataset that contains data about it." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nlm-ckn:CellSetDataset ;
            sh:description "A dataset that is about cells taken from one or more tissue samples." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:class nlm-ckn:CellSet ;
            sh:description "A collection of cells that have some common property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between some information content entity and the resource from which it originated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellSetHasSourceCellSetDataset .

nlm-ckn:CellTypeDevelopsFromCellType a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell type and another cell type it directly or indirectly develops from." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Relation between entities x and y and some process p where x is the input to p and y is the output of p and x is directly involved in the creation of y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellTypeDevelopsFromCellType .

nlm-ckn:CellTypeExpressesGene a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell type and a gene such that the gene is selectively expressed in that cell type and can be used as a marker." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a cell type and a gene that is selectively expressed in that cell type relative to other cell types." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class SO:0000704 ;
            sh:description "A region (or regions) that includes all of the sequence elements necessary to encode a functional transcript. A gene may include regulatory regions, transcribed regions and/or other functional sequence regions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellTypeExpressesGene .

nlm-ckn:CellTypeHasExemplarDataCellSetDataset a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell type and a dataset in which some of the data exemplify the cell type." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class nlm-ckn:CellSetDataset ;
            sh:description "A dataset that is about cells taken from one or more tissue samples." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between an entity and some data in which the data are taken as exemplifying the material entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellTypeHasExemplarDataCellSetDataset .

nlm-ckn:CellTypeHasPlasmaMembranePartProtein a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell type and a protein that is part of its plasma membrane." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:class PR:000000001 ;
            sh:description "An amino acid chain that is canonically produced de novo by ribosome-mediated translation of a genetically-encoded mRNA, and any derivatives thereof" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation between a cell c and a protein complex or protein p that is part of the cell's plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ] ;
    sh:targetClass nlm-ckn:CellTypeHasPlasmaMembranePartProtein .

nlm-ckn:CellTypeInteractsWithCellType a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between two cell types that are causally connected." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Symmetric relation between two entities that directly bind or modify the behavior of the other." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ] ;
    sh:targetClass nlm-ckn:CellTypeInteractsWithCellType .

nlm-ckn:CellTypeLacksPlasmaMembranePartProtein a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship between a cell type and a protein that is not part of its plasma membrane but is part of the plasma membrane of related cell types." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class CL:0000000 ;
            sh:description "A material entity of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nlm-ckn:subject ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A relation that asserts the lack of a presence of some cellular component in a cell's plasma membrane." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nlm-ckn:predicate ],
        [ sh:class PR:000000001 ;
            sh:description "An amino acid chain that is canonically produced de novo by ribosome-mediated translation of a genetically-encoded mRNA, and any derivatives thereof" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nlm-ckn:object ] ;
    sh:targetClass nlm-ckn:CellTypeLacksPlasmaMembranePartProtein .

